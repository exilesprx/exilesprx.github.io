---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
const author = 'Soupy Butter';

const socialLinks = [
  {
    name: 'GitHub',
    url: 'https://github.com/exilesprx',
    icon: 'fa6-brands:github'
  },
  {
    name: 'LinkedIn',
    url: 'https://www.linkedin.com/in/andrew-campbell-014002134/',
    icon: 'fa6-brands:linkedin'
  },
  {
    name: 'Company',
    url: 'https://soupybutter.com',
    icon: 'fa6-solid:building'
  }
];

const navLinks = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/posts' },
  { name: 'About', url: '/#about' },
  { name: 'For Hire', url: '/for-hire' },
  { name: 'Portfolio', url: '/portfolio' },
  { name: 'Contact', url: 'mailto:exiles.prx@gmail.com' }
];
---

<footer
  class="text-primary dark-mode-transition border-t border-gray-200 bg-gray-100 dark:border-slate-700 dark:bg-slate-800 dark:text-white"
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <!-- Top footer section with links -->
    <div class="mb-8 grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Logo/branding section -->
      <div class="flex flex-col">
        <h2 class="mb-3 text-xl font-bold">Andrew Campbell</h2>
        <p class="text-primary/70 mb-4 text-sm dark:text-white/70">
          Software Engineer specializing in web development and creating elegant
          solutions to complex problems.
        </p>
      </div>

      <!-- Quick links -->
      <div class="flex flex-col">
        <h3 class="text-primary mb-3 font-semibold dark:text-white">Links</h3>
        <nav class="flex flex-col space-y-2">
          {
            navLinks.map((link) => (
              <a
                href={link.url}
                class="text-primary/70 hover:text-primary text-sm transition-colors dark:text-white/70 dark:hover:text-white"
              >
                {link.name}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Connect section -->
      <div class="flex flex-col">
        <h3 class="text-primary mb-3 font-semibold dark:text-white">Connect</h3>
        <div class="flex flex-wrap gap-4">
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary/70 hover:text-primary flex items-center transition-colors dark:text-white/70 dark:hover:text-white"
                aria-label={`Visit ${link.name}`}
              >
                <Icon
                  name={link.icon}
                  class="size-5"
                />
                <span class="ml-2 text-sm">{link.name}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom footer with copyright -->
    <div
      class="text-primary/70 flex flex-col justify-between border-t border-gray-200 pt-6 text-sm md:flex-row dark:border-slate-700 dark:text-white/70"
    >
      <p>&#169; {year} {author}. All rights reserved.</p>
      <p class="mt-2 md:mt-0">Built with Astro and Tailwind CSS</p>
    </div>
  </div>
</footer>
