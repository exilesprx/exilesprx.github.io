---
interface PostCardProps {
  title: string;
  date: string;
  tags: string[];
  link: string;
}

const { title, date, tags, link } = Astro.props as PostCardProps;
---

<section>
  <article
    class="dark-mode-transition my-4 rounded-[10px] border border-gray-200 bg-white px-4 pt-12 pb-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 dark:shadow-slate-900/50"
  >
    <time
      datetime="2022-10-10"
      class="text-primary/70 block text-xs dark:text-white/70"
    >
      {date}
    </time>

    <a
      href={link}
      class="no-underline"
    >
      <h3
        class="text-primary hover:text-primary/80 mt-0.5 text-lg font-medium transition-colors dark:text-white dark:hover:text-white/80"
      >
        {title}
      </h3>
    </a>

    <div class="mt-4 flex flex-wrap gap-1">
      {
        tags.map((tag) => (
          <span class="rounded-full bg-purple-100 px-2.5 py-0.5 text-xs whitespace-nowrap text-purple-600 dark:bg-purple-100/10 dark:text-purple-400">
            {tag}
          </span>
        ))
      }
    </div>
  </article>
</section>
